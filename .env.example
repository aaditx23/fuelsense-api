# ----------------------------------------------------------------------------
# FuelSense Backend environment template
# Copy this file to .env (and optionally .env.local) and fill real values.
# ----------------------------------------------------------------------------

# App
PORT=3000
NODE_ENV=development
APP_NAME=FuelSense API
APP_VERSION=1.0.0
DEBUG=true

# Auth
# Use a long random value in production.
SECRET_KEY=replace_with_a_strong_secret

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Admin seed credentials
ADMIN_SEED_EMAIL=admin@fuelsense.com
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_USERNAME=admin_fuelsense

# Database
# Runtime DB URL (for Prisma client / app runtime)
DATABASE_URL=postgresql://username:password@host:5432/database

# Direct DB URL (for Prisma migrations)
DIRECT_URL=postgresql://username:password@host:5432/database

# ----------------------------------------------------------------------------
# Supabase suggestion (if you use Supabase):
# DATABASE_URL -> pooler URL (port 6543, often with pgbouncer=true)
# DIRECT_URL   -> direct URL (port 5432)
# ----------------------------------------------------------------------------
